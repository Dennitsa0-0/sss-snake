#!/usr/bin/env bash
set -euo pipefail

VERSION='0.4.0'

show_help() {
  cat <<'HELP'
SSS Snake

Usage:
  sss [snake] [options]
  sss status
  sss --version
  sss --help

Commands:
  snake         Start SSS Snake. This is the default command.
  status        Show tmux and launcher status.

Launcher options:
  --no-tmux       Run directly without checking or starting tmux.
  --no-install    Do not offer to install tmux when it is missing.
  --install-tmux  Install tmux without asking when it is missing.

Game options:
  --width N        Board width.
  --height N       Board height.
  --fruits N       Fruits on the board, 1..20.
  --big-food       Use larger fruit hitboxes.
  --wrap           Enable wrap-around edges.
  --no-wrap        Keep edges as walls.
  --path-refresh N Rebuild autopilot path every N ticks.
  --ai MODE        Autopilot mode: safe, smart, dumb.
  --lookahead N    Safe AI lookahead depth.
  --open-radius N  Radius for local open-space scoring.
  --memory N       Head positions remembered for loop detection.
  --emergency-after N Stale ticks before emergency mode.
  --max-ai-cells N Use greedy AI above this board area.
  --max-ai-steps N Maximum BFS nodes per path rebuild.
  --idle-ticks N   Ticks before manual mode returns to autopilot.
  --theme NAME     classic, matrix, ocean, ember, mono.
  --ascii          Use ASCII symbols.
  --unicode        Use Unicode symbols.
  --no-score       Do not read or write the high score file.
  --version        Show version.
  --help          Show game help.

Environment:
  SSS_TMUX_SESSION       tmux session name, default: sss-snake
  SSS_NO_TMUX=1          disable tmux wrapper
  SSS_NO_INSTALL_PROMPT=1 do not ask to install tmux
HELP
}

script_dir="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
snake_bin='sss-snake'
if [[ -x "$script_dir/sss-snake" ]]; then
  snake_bin="$script_dir/sss-snake"
fi

run_snake() {
  exec "$snake_bin" "$@"
}

run_in_tmux() {
  local session game_cmd arg
  session="${SSS_TMUX_SESSION:-sss-snake}"
  game_cmd="$(printf '%q' "$snake_bin")"
  for arg in "$@"; do
    game_cmd+=" $(printf '%q' "$arg")"
  done
  exec tmux new-session -A -s "$session" "$game_cmd"
}

show_status() {
  local session tmux_status session_status wrapper_status prompt_status score_status inside_tmux

  session="${SSS_TMUX_SESSION:-sss-snake}"
  tmux_status='not found'
  session_status='unknown'
  wrapper_status='enabled'
  prompt_status='enabled'
  score_status='enabled'
  inside_tmux='no'

  [[ "${SSS_NO_TMUX:-0}" == "1" ]] && wrapper_status='disabled by SSS_NO_TMUX'
  [[ -n "${SSS_NO_INSTALL_PROMPT:-}" ]] && prompt_status='disabled by SSS_NO_INSTALL_PROMPT'
  [[ -n "${SSS_NO_SCORE:-}" ]] && score_status='disabled by SSS_NO_SCORE'
  [[ -n "${TMUX:-}" ]] && inside_tmux='yes'

  if command -v tmux >/dev/null 2>&1; then
    tmux_status="installed ($(command -v tmux))"
    if tmux has-session -t "$session" >/dev/null 2>&1; then
      session_status='running'
    else
      session_status='not running'
    fi
  fi

  cat <<STATUS
SSS Snake status

tmux:          $tmux_status
inside tmux:   $inside_tmux
session:       $session ($session_status)
tmux wrapper:  $wrapper_status
install prompt: $prompt_status
score file:    $score_status
game command:  $snake_bin
STATUS
}

detect_package_manager() {
  local manager
  for manager in apt dnf yum pacman zypper apk brew; do
    if command -v "$manager" >/dev/null 2>&1; then
      printf '%s\n' "$manager"
      return 0
    fi
  done
  return 1
}

install_tmux_with_manager() {
  local manager="$1"
  local -a cmd

  case "$manager" in
    apt)    cmd=(apt install -y tmux) ;;
    dnf)    cmd=(dnf install -y tmux) ;;
    yum)    cmd=(yum install -y tmux) ;;
    pacman) cmd=(pacman -S --noconfirm tmux) ;;
    zypper) cmd=(zypper install -y tmux) ;;
    apk)    cmd=(apk add tmux) ;;
    brew)   cmd=(brew install tmux) ;;
    *)      return 1 ;;
  esac

  if [[ "$manager" == "brew" || "${EUID:-$(id -u)}" == "0" ]]; then
    "${cmd[@]}"
    return $?
  fi

  if ! command -v sudo >/dev/null 2>&1; then
    echo "sudo is not available." >&2
    echo "Please install tmux manually, or run SSS Snake without tmux." >&2
    return 1
  fi

  echo "Installing tmux requires administrator permissions." >&2
  echo "You may be asked for your sudo password." >&2
  sudo "${cmd[@]}"
}

install_tmux() {
  local manager

  if ! manager="$(detect_package_manager)"; then
    echo "Could not detect a supported package manager." >&2
    echo "Please install tmux manually, or run SSS Snake without tmux." >&2
    return 1
  fi

  if install_tmux_with_manager "$manager"; then
    command -v tmux >/dev/null 2>&1
    return $?
  fi

  return 1
}

maybe_install_tmux() {
  local install_mode="$1"
  local answer

  if [[ "$install_mode" == "auto" ]]; then
    install_tmux
    return $?
  fi

  if [[ "$install_mode" == "never" || -n "${SSS_NO_INSTALL_PROMPT:-}" ]]; then
    return 1
  fi

  echo "tmux is not installed." >&2
  echo >&2
  echo "SSS Snake can work without tmux, but tmux is recommended." >&2
  echo "It keeps your terminal session alive on the server even if SSH disconnects." >&2
  echo >&2
  printf 'Install tmux now? [y/N] ' >&2

  if ! IFS= read -r answer; then
    echo >&2
    echo "Continuing without tmux." >&2
    return 1
  fi

  case "$answer" in
    y|Y|yes|YES)
      if install_tmux; then
        return 0
      fi
      echo "tmux installation failed." >&2
      echo "Continuing without tmux." >&2
      return 1
      ;;
    ''|n|N|no|NO)
      echo "Continuing without tmux." >&2
      echo "Your snake will run directly in the current SSH session." >&2
      echo "If SSH disconnects, this session may stop." >&2
      return 1
      ;;
    *)
      echo "Unknown answer. Continuing without tmux." >&2
      return 1
      ;;
  esac
}

if [[ $# -gt 0 ]]; then
  case "$1" in
    snake)
      shift
      ;;
    status)
      show_status
      exit 0
      ;;
    --version)
      echo "SSS Snake $VERSION"
      exit 0
      ;;
    -h|--help|help)
      show_help
      exit 0
      ;;
    -*)
      ;;
    *)
      echo "Unknown command: $1" >&2
      echo "Run: sss --help" >&2
      exit 2
      ;;
  esac
fi

no_tmux="${SSS_NO_TMUX:-0}"
install_mode="ask"
args=()
for arg in "$@"; do
  case "$arg" in
    --no-tmux)
      no_tmux=1
      ;;
    --no-install)
      install_mode="never"
      ;;
    --install-tmux)
      install_mode="auto"
      ;;
    *)
      args+=("$arg")
      ;;
  esac
done

for arg in "${args[@]}"; do
  case "$arg" in
    -h|--help|help|--version)
      run_snake "${args[@]}"
      ;;
  esac
done

if [[ "$no_tmux" == "1" || -n "${TMUX:-}" ]]; then
  run_snake "${args[@]}"
fi

if command -v tmux >/dev/null 2>&1; then
  run_in_tmux "${args[@]}"
fi

if maybe_install_tmux "$install_mode"; then
  echo "tmux installed successfully." >&2
  echo "Starting SSS Snake inside tmux..." >&2
  run_in_tmux "${args[@]}"
fi

if [[ "$install_mode" == "auto" ]]; then
  echo "tmux installation failed." >&2
  echo "Continuing without tmux." >&2
fi

run_snake "${args[@]}"
