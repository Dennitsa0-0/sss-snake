#!/usr/bin/env bash
set -u

if (( BASH_VERSINFO[0] < 4 )); then
  echo "SSS Snake requires Bash 4+ because it uses associative arrays." >&2
  exit 1
fi

VERSION='0.4.0'

show_help() {
  cat <<'HELP'
SSS Snake - a terminal snake that can idle safely in SSH sessions.

Usage:
  sss-snake [delay] [options]
  sss-snake --help

Arguments:
  delay              Frame delay in seconds. Default: 0.12

Options:
  --width N          Board width. Default: 50, capped by terminal
  --height N         Board height. Default: 16, capped by terminal
  --fruits N         Fruits on the board, 1..20. Default: 4
  --big-food         Fruit hitboxes use radius 1
  --wrap             Enable wrap-around edges
  --no-wrap          Keep edges as walls. Default
  --path-refresh N   Rebuild smart autopilot path every N ticks. Default: 10
  --ai MODE          Autopilot mode: safe, smart, dumb. Default: safe
  --max-ai-cells N   Use greedy AI above this board area. Default: 1200
  --max-ai-steps N   Maximum BFS nodes per path rebuild. Default: 300
  --idle-ticks N     Ticks before manual mode returns to autopilot
  --theme NAME       classic, matrix, ocean, ember, mono
  --ascii            Force ASCII symbols
  --unicode          Try Unicode; warn and fall back if UTF-8 is unavailable
  --no-score         Do not read or write the high score file
  --help             Show this help
  --version          Show version

Controls:
  Arrow keys         Play manually
  W A S D            Play manually
  T or Space         Toggle auto/manual mode
  R                  Restart board
  Q                  Quit

Environment:
  SSS_WIDTH          Default board width
  SSS_HEIGHT         Default board height
  SSS_FRUITS         Default fruit count, 4
  SSS_IDLE_TICKS     Default idle ticks, 160
  SSS_PATH_REFRESH   Default path refresh ticks, 10
  SSS_AI             Default AI mode: safe, smart, dumb
  SSS_MAX_AI_CELLS   Default max board cells for smart BFS, 1200
  SSS_MAX_AI_STEPS   Default BFS node limit, 300
  SSS_THEME          Default theme
  SSS_ASCII=1        Use ASCII symbols
  SSS_NO_SCORE=1     Disable high score persistence
  NO_COLOR=1         Disable color output
HELP
}

die() {
  echo "sss-snake: $*" >&2
  exit 2
}

is_uint() {
  [[ "$1" =~ ^[0-9]+$ ]]
}

clamp() {
  local value="$1" min="$2" max="$3"
  (( value < min )) && value="$min"
  (( value > max )) && value="$max"
  printf '%s\n' "$value"
}

terminal_number() {
  local cap="$1" fallback="$2" value
  value="$(tput "$cap" 2>/dev/null || true)"
  if [[ "$value" =~ ^[0-9]+$ && "$value" -gt 0 ]]; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "$fallback"
  fi
}

utf8_available() {
  local charmap locale_text
  charmap="$(locale charmap 2>/dev/null || true)"
  locale_text="${LC_ALL:-} ${LC_CTYPE:-} ${LANG:-} $charmap"
  [[ "$locale_text" =~ ([Uu][Tt][Ff]-?8) ]]
}

DELAY='0.12'
WIDTH_ARG=''
HEIGHT_ARG=''
FRUIT_TARGET="${SSS_FRUITS:-4}"
BIG_FOOD=0
WRAP=0
PATH_REFRESH="${SSS_PATH_REFRESH:-10}"
AI_MODE="${SSS_AI:-safe}"
MAX_AI_CELLS="${SSS_MAX_AI_CELLS:-1200}"
MAX_AI_STEPS="${SSS_MAX_AI_STEPS:-300}"
IDLE_TICKS="${SSS_IDLE_TICKS:-160}"
THEME="${SSS_THEME:-classic}"
UNICODE_MODE='auto'
SCORE_ENABLED=1
delay_seen=0

[[ "${SSS_ASCII:-0}" == "1" ]] && UNICODE_MODE='ascii'
[[ -n "${SSS_NO_SCORE:-}" ]] && SCORE_ENABLED=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help|help)
      show_help
      exit 0
      ;;
    --version)
      echo "SSS Snake $VERSION"
      exit 0
      ;;
    --width)
      [[ $# -ge 2 ]] || die "--width requires a value"
      is_uint "$2" || die "--width must be a positive integer"
      WIDTH_ARG="$2"
      shift 2
      ;;
    --height)
      [[ $# -ge 2 ]] || die "--height requires a value"
      is_uint "$2" || die "--height must be a positive integer"
      HEIGHT_ARG="$2"
      shift 2
      ;;
    --fruits)
      [[ $# -ge 2 ]] || die "--fruits requires a value"
      is_uint "$2" || die "--fruits must be a positive integer"
      FRUIT_TARGET="$2"
      shift 2
      ;;
    --big-food)
      BIG_FOOD=1
      shift
      ;;
    --wrap)
      WRAP=1
      shift
      ;;
    --no-wrap)
      WRAP=0
      shift
      ;;
    --path-refresh)
      [[ $# -ge 2 ]] || die "--path-refresh requires a value"
      is_uint "$2" || die "--path-refresh must be a positive integer"
      PATH_REFRESH="$2"
      shift 2
      ;;
    --ai)
      [[ $# -ge 2 ]] || die "--ai requires a value"
      AI_MODE="$2"
      shift 2
      ;;
    --max-ai-cells)
      [[ $# -ge 2 ]] || die "--max-ai-cells requires a value"
      is_uint "$2" || die "--max-ai-cells must be a positive integer"
      MAX_AI_CELLS="$2"
      shift 2
      ;;
    --max-ai-steps|--max-ai-steps-per-tick)
      [[ $# -ge 2 ]] || die "--max-ai-steps requires a value"
      is_uint "$2" || die "--max-ai-steps must be a positive integer"
      MAX_AI_STEPS="$2"
      shift 2
      ;;
    --idle-ticks)
      [[ $# -ge 2 ]] || die "--idle-ticks requires a value"
      is_uint "$2" || die "--idle-ticks must be a positive integer"
      IDLE_TICKS="$2"
      shift 2
      ;;
    --theme)
      [[ $# -ge 2 ]] || die "--theme requires a value"
      THEME="$2"
      shift 2
      ;;
    --ascii)
      UNICODE_MODE='ascii'
      shift
      ;;
    --unicode)
      UNICODE_MODE='unicode'
      shift
      ;;
    --no-score)
      SCORE_ENABLED=0
      shift
      ;;
    --)
      shift
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      if (( delay_seen == 1 )); then
        die "unexpected argument: $1"
      fi
      DELAY="$1"
      delay_seen=1
      shift
      ;;
  esac
done

[[ "$DELAY" =~ ^([0-9]+([.][0-9]+)?|[.][0-9]+)$ ]] || die "delay must be a number"
is_uint "$IDLE_TICKS" || die "idle ticks must be a positive integer"
is_uint "$PATH_REFRESH" || die "path refresh must be a positive integer"
is_uint "$MAX_AI_CELLS" || die "max AI cells must be a positive integer"
is_uint "$MAX_AI_STEPS" || die "max AI steps must be a positive integer"
is_uint "$FRUIT_TARGET" || die "fruit count must be a positive integer"
(( IDLE_TICKS < 1 )) && IDLE_TICKS=1
(( PATH_REFRESH < 1 )) && PATH_REFRESH=1
(( MAX_AI_CELLS < 1 )) && MAX_AI_CELLS=1
(( MAX_AI_STEPS < 1 )) && MAX_AI_STEPS=1
FRUIT_TARGET="$(clamp "$FRUIT_TARGET" 1 20)"

case "$AI_MODE" in
  safe|smart|dumb) ;;
  *) die "ai mode must be safe, smart, or dumb" ;;
esac

cols="$(terminal_number cols 80)"
lines="$(terminal_number lines 24)"

if (( cols < 24 || lines < 17 )); then
  echo "Terminal is too small. Need at least 24x17." >&2
  exit 1
fi

max_w=$((cols - 4))
max_h=$((lines - 7))
W="${WIDTH_ARG:-${SSS_WIDTH:-50}}"
H="${HEIGHT_ARG:-${SSS_HEIGHT:-16}}"

is_uint "$W" || die "width must be a positive integer"
is_uint "$H" || die "height must be a positive integer"

W="$(clamp "$W" 20 "$max_w")"
H="$(clamp "$H" 10 "$max_h")"

USE_ASCII=0
if [[ "$UNICODE_MODE" == 'ascii' ]]; then
  USE_ASCII=1
elif utf8_available; then
  USE_ASCII=0
else
  USE_ASCII=1
  if [[ "$UNICODE_MODE" == 'unicode' ]]; then
    echo "Warning: UTF-8 locale is unavailable; using ASCII mode." >&2
    sleep 1
  fi
fi

if (( USE_ASCII == 1 )); then
  TL='+'; TR='+'; BL='+'; BR='+'; HH='-'; VV='|'
  HEAD='@'; BODY='o'; EMPTY=' '
  APPLE_SYM='o'; PEAR_SYM='O'; BERRY_SYM='*'; BONUS_SYM='$'
else
  TL='┌'; TR='┐'; BL='└'; BR='┘'; HH='─'; VV='│'
  HEAD='◆'; BODY='▪'; EMPTY=' '
  APPLE_SYM='●'; PEAR_SYM='◉'; BERRY_SYM='•'; BONUS_SYM='◆'
fi

COLOR_RESET=''
COLOR_BORDER=''
COLOR_HEAD=''
COLOR_BODY=''
COLOR_APPLE=''
COLOR_ACCENT=''

setup_colors() {
  local colors
  [[ -n "${NO_COLOR:-}" ]] && return 0
  colors="$(tput colors 2>/dev/null || echo 0)"
  [[ "$colors" =~ ^[0-9]+$ ]] || colors=0
  (( colors >= 8 )) || return 0

  COLOR_RESET="$(tput sgr0 2>/dev/null || true)"

  case "$THEME" in
    classic)
      COLOR_BORDER="$(tput setaf 6 2>/dev/null || true)"
      COLOR_HEAD="$(tput setaf 2 2>/dev/null || true)"
      COLOR_BODY="$(tput setaf 10 2>/dev/null || tput setaf 2 2>/dev/null || true)"
      COLOR_APPLE="$(tput setaf 1 2>/dev/null || true)"
      COLOR_ACCENT="$(tput setaf 3 2>/dev/null || true)"
      ;;
    matrix)
      COLOR_BORDER="$(tput setaf 2 2>/dev/null || true)"
      COLOR_HEAD="$(tput setaf 15 2>/dev/null || true)"
      COLOR_BODY="$(tput setaf 10 2>/dev/null || tput setaf 2 2>/dev/null || true)"
      COLOR_APPLE="$(tput setaf 11 2>/dev/null || tput setaf 3 2>/dev/null || true)"
      COLOR_ACCENT="$(tput setaf 10 2>/dev/null || tput setaf 2 2>/dev/null || true)"
      ;;
    ocean)
      COLOR_BORDER="$(tput setaf 4 2>/dev/null || true)"
      COLOR_HEAD="$(tput setaf 14 2>/dev/null || tput setaf 6 2>/dev/null || true)"
      COLOR_BODY="$(tput setaf 6 2>/dev/null || true)"
      COLOR_APPLE="$(tput setaf 13 2>/dev/null || tput setaf 5 2>/dev/null || true)"
      COLOR_ACCENT="$(tput setaf 12 2>/dev/null || tput setaf 4 2>/dev/null || true)"
      ;;
    ember)
      COLOR_BORDER="$(tput setaf 3 2>/dev/null || true)"
      COLOR_HEAD="$(tput setaf 11 2>/dev/null || tput setaf 3 2>/dev/null || true)"
      COLOR_BODY="$(tput setaf 9 2>/dev/null || tput setaf 1 2>/dev/null || true)"
      COLOR_APPLE="$(tput setaf 15 2>/dev/null || true)"
      COLOR_ACCENT="$(tput setaf 1 2>/dev/null || true)"
      ;;
    mono)
      ;;
    *)
      echo "Unknown theme '$THEME'; using classic." >&2
      THEME='classic'
      COLOR_BORDER="$(tput setaf 6 2>/dev/null || true)"
      COLOR_HEAD="$(tput setaf 2 2>/dev/null || true)"
      COLOR_BODY="$(tput setaf 2 2>/dev/null || true)"
      COLOR_APPLE="$(tput setaf 1 2>/dev/null || true)"
      COLOR_ACCENT="$(tput setaf 3 2>/dev/null || true)"
      ;;
  esac
}

colorize() {
  local color="$1" text="$2"
  if [[ -n "$color" ]]; then
    printf '%s%s%s' "$color" "$text" "$COLOR_RESET"
  else
    printf '%s' "$text"
  fi
}

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/sss-snake"
score_file="$state_dir/high-score"
high_score=0

load_high_score() {
  local value
  (( SCORE_ENABLED == 1 )) || return 0
  [[ -r "$score_file" ]] || return 0
  value="$(head -n 1 "$score_file" 2>/dev/null || true)"
  if [[ "$value" =~ ^[0-9]+$ ]]; then
    high_score="$value"
  fi
}

save_high_score() {
  (( SCORE_ENABLED == 1 )) || return 0
  (( score_total > 0 )) || return 0
  (( score_total >= high_score )) || return 0
  mkdir -p "$state_dir" 2>/dev/null || return 0
  printf '%s\n' "$score_total" >"$score_file" 2>/dev/null || true
}

declare -a body_x body_y fruit_x fruit_y fruit_type fruit_points fruit_grow fruit_radius path_x path_y bfs_path_x bfs_path_y
declare -A snake fruit_center fruit_hit fruit_symbol fruit_score fruit_growth

score_total=0
score_auto_away=0
score_manual=0
restarts=0
mode='auto'
dir='RIGHT'
manual_idle=0
length=5
growth_pending=0
eat_grow=0
fruit_count=0
tick=0
path_index=0
path_dirty=1
old_stty=''

fruit_symbol[apple]="$APPLE_SYM"; fruit_score[apple]=1; fruit_growth[apple]=1
fruit_symbol[pear]="$PEAR_SYM"; fruit_score[pear]=2; fruit_growth[pear]=1
fruit_symbol[berry]="$BERRY_SYM"; fruit_score[berry]=1; fruit_growth[berry]=0
fruit_symbol[bonus]="$BONUS_SYM"; fruit_score[bonus]=5; fruit_growth[bonus]=2

fruit_kind_random() {
  local r=$((RANDOM % 100))
  if (( r < 50 )); then
    printf 'apple\n'
  elif (( r < 75 )); then
    printf 'pear\n'
  elif (( r < 92 )); then
    printf 'berry\n'
  else
    printf 'bonus\n'
  fi
}

rebuild_fruit_maps() {
  local i x y r dx dy hx hy
  fruit_center=()
  fruit_hit=()
  for ((i=0; i<fruit_count; i++)); do
    [[ -n "${fruit_x[$i]+x}" ]] || continue
    x="${fruit_x[$i]}"
    y="${fruit_y[$i]}"
    r="${fruit_radius[$i]}"
    fruit_center["$x,$y"]="$i"
    for ((dy=-r; dy<=r; dy++)); do
      for ((dx=-r; dx<=r; dx++)); do
        hx=$((x + dx))
        hy=$((y + dy))
        fruit_hit["$hx,$hy"]="$i"
      done
    done
  done
}

fruit_space_ok() {
  local x="$1" y="$2" radius="$3" ignore="${4:--1}" dx dy hx hy idx
  for ((dy=-radius; dy<=radius; dy++)); do
    for ((dx=-radius; dx<=radius; dx++)); do
      hx=$((x + dx))
      hy=$((y + dy))
      (( hx >= 0 && hx < W && hy >= 0 && hy < H )) || return 1
      [[ -z "${snake[$hx,$hy]+x}" ]] || return 1
      if [[ -n "${fruit_hit[$hx,$hy]+x}" ]]; then
        idx="${fruit_hit[$hx,$hy]}"
        (( idx == ignore )) || return 1
      fi
    done
  done
  return 0
}

spawn_fruit() {
  local slot="$1" tries=0 x y kind radius
  radius=0
  (( BIG_FOOD == 1 )) && radius=1
  while true; do
    x=$((RANDOM % W))
    y=$((RANDOM % H))
    if fruit_space_ok "$x" "$y" "$radius" "$slot"; then
      kind="$(fruit_kind_random)"
      fruit_x[$slot]="$x"
      fruit_y[$slot]="$y"
      fruit_type[$slot]="$kind"
      fruit_points[$slot]="${fruit_score[$kind]}"
      fruit_grow[$slot]="${fruit_growth[$kind]}"
      fruit_radius[$slot]="$radius"
      (( slot >= fruit_count )) && fruit_count=$((slot + 1))
      rebuild_fruit_maps
      path_dirty=1
      return 0
    fi

    tries=$((tries + 1))
    if (( tries > W * H * 3 )); then
      return 1
    fi
  done
}

fill_fruits() {
  local i
  rebuild_fruit_maps
  for ((i=0; i<FRUIT_TARGET; i++)); do
    [[ -n "${fruit_x[$i]+x}" ]] || spawn_fruit "$i" >/dev/null || true
  done
  rebuild_fruit_maps
}

active_fruit_count() {
  local i count=0
  for ((i=0; i<fruit_count; i++)); do
    [[ -n "${fruit_x[$i]+x}" ]] && count=$((count + 1))
  done
  printf '%s\n' "$count"
}

reset_board() {
  local i x y start_x start_y
  snake=()
  body_x=()
  body_y=()
  fruit_x=()
  fruit_y=()
  fruit_type=()
  fruit_points=()
  fruit_grow=()
  fruit_radius=()
  fruit_count=0
  path_x=()
  path_y=()
  path_index=0
  path_dirty=1

  length=5
  growth_pending=0
  dir='RIGHT'
  mode='auto'
  manual_idle=0

  start_x=$((W / 2))
  start_y=$((H / 2))
  (( start_x < length )) && start_x=$length

  for ((i=0; i<length; i++)); do
    x=$((start_x - i))
    y=$start_y
    body_x[$i]=$x
    body_y[$i]=$y
    snake["$x,$y"]=1
  done

  fill_fruits
}

enter_manual() {
  mode='manual'
  manual_idle=0
  path_dirty=1
}

enter_auto() {
  mode='auto'
  manual_idle=0
  path_dirty=1
}

opposite_dir() {
  local a="$1" b="$2"
  [[ "$a" == 'UP' && "$b" == 'DOWN' ]] && return 0
  [[ "$a" == 'DOWN' && "$b" == 'UP' ]] && return 0
  [[ "$a" == 'LEFT' && "$b" == 'RIGHT' ]] && return 0
  [[ "$a" == 'RIGHT' && "$b" == 'LEFT' ]] && return 0
  return 1
}

set_direction() {
  local new_dir="$1"
  enter_manual
  if ! opposite_dir "$dir" "$new_dir"; then
    dir="$new_dir"
  fi
}

next_coord() {
  local d="$1" x="$2" y="$3" nx="$2" ny="$3"
  case "$d" in
    UP)    ny=$((ny - 1)) ;;
    DOWN)  ny=$((ny + 1)) ;;
    LEFT)  nx=$((nx - 1)) ;;
    RIGHT) nx=$((nx + 1)) ;;
  esac

  if (( WRAP == 1 )); then
    (( nx < 0 )) && nx=$((W - 1))
    (( nx >= W )) && nx=0
    (( ny < 0 )) && ny=$((H - 1))
    (( ny >= H )) && ny=0
  fi

  printf '%s %s\n' "$nx" "$ny"
}

direction_to() {
  local x="$1" y="$2" nx="$3" ny="$4"
  if (( nx == x && ny == y - 1 )); then printf 'UP\n'; return; fi
  if (( nx == x && ny == y + 1 )); then printf 'DOWN\n'; return; fi
  if (( nx == x - 1 && ny == y )); then printf 'LEFT\n'; return; fi
  if (( nx == x + 1 && ny == y )); then printf 'RIGHT\n'; return; fi
  if (( WRAP == 1 )); then
    if (( x == 0 && nx == W - 1 && ny == y )); then printf 'LEFT\n'; return; fi
    if (( x == W - 1 && nx == 0 && ny == y )); then printf 'RIGHT\n'; return; fi
    if (( y == 0 && ny == H - 1 && nx == x )); then printf 'UP\n'; return; fi
    if (( y == H - 1 && ny == 0 && nx == x )); then printf 'DOWN\n'; return; fi
  fi
  printf '%s\n' "$dir"
}

safe_cell() {
  local nx="$1" ny="$2" allow_tail="${3:-1}" tail_x tail_y
  (( nx >= 0 && nx < W && ny >= 0 && ny < H )) || return 1
  if [[ -n "${snake[$nx,$ny]+x}" ]]; then
    if (( allow_tail == 1 && length > 0 )); then
      tail_x="${body_x[$((length - 1))]}"
      tail_y="${body_y[$((length - 1))]}"
      (( nx == tail_x && ny == tail_y )) && return 0
    fi
    return 1
  fi
  return 0
}

restart_keep_score() {
  restarts=$((restarts + 1))
  reset_board
}

eat_fruit() {
  local idx="$1" points grow
  eat_grow=0
  points="${fruit_points[$idx]:-1}"
  grow="${fruit_grow[$idx]:-1}"
  score_total=$((score_total + points))
  (( score_total > high_score )) && high_score=$score_total
  if [[ "$mode" == 'auto' ]]; then
    score_auto_away=$((score_auto_away + 1))
  else
    score_manual=$((score_manual + points))
  fi
  unset "fruit_x[$idx]" "fruit_y[$idx]" "fruit_type[$idx]" "fruit_points[$idx]" "fruit_grow[$idx]" "fruit_radius[$idx]"
  spawn_fruit "$idx" >/dev/null || true
  path_dirty=1
  eat_grow="$grow"
}

move_to() {
  local nx="$1" ny="$2" fruit_idx='' grow=0 grow_add=0 remove_tail=1 had_pending=0 tail_x tail_y i

  if (( nx < 0 || nx >= W || ny < 0 || ny >= H )); then
    restart_keep_score
    return
  fi

  if [[ -n "${fruit_hit[$nx,$ny]+x}" ]]; then
    fruit_idx="${fruit_hit[$nx,$ny]}"
    grow="${fruit_grow[$fruit_idx]:-1}"
  fi

  (( growth_pending > 0 )) && had_pending=1
  if (( had_pending == 1 || grow > 0 )); then
    remove_tail=0
  fi

  if (( remove_tail == 1 )); then
    tail_x="${body_x[$((length - 1))]}"
    tail_y="${body_y[$((length - 1))]}"
    unset "snake[$tail_x,$tail_y]"
  fi

  if [[ -n "${snake[$nx,$ny]+x}" ]]; then
    restart_keep_score
    return
  fi

  if (( remove_tail == 0 )); then
    length=$((length + 1))
  fi

  for ((i=length-1; i>0; i--)); do
    body_x[$i]="${body_x[$((i - 1))]}"
    body_y[$i]="${body_y[$((i - 1))]}"
  done

  body_x[0]=$nx
  body_y[0]=$ny
  snake["$nx,$ny"]=1

  if [[ -n "$fruit_idx" ]]; then
    eat_fruit "$fruit_idx"
    grow_add="$eat_grow"
    if (( had_pending == 1 )); then
      growth_pending=$((growth_pending - 1))
    fi
    if (( grow_add > 1 )); then
      growth_pending=$((growth_pending + grow_add - 1))
    fi
  elif (( had_pending == 1 )); then
    growth_pending=$((growth_pending - 1))
  fi

  if (( length >= W * H - 1 )); then
    reset_board
  fi
}

left_of() {
  case "$1" in
    UP) printf 'LEFT\n' ;;
    LEFT) printf 'DOWN\n' ;;
    DOWN) printf 'RIGHT\n' ;;
    RIGHT) printf 'UP\n' ;;
  esac
}

right_of() {
  case "$1" in
    UP) printf 'RIGHT\n' ;;
    RIGHT) printf 'DOWN\n' ;;
    DOWN) printf 'LEFT\n' ;;
    LEFT) printf 'UP\n' ;;
  esac
}

direction_safe() {
  local d="$1" nx ny
  opposite_dir "$dir" "$d" && return 1
  read -r nx ny < <(next_coord "$d" "${body_x[0]}" "${body_y[0]}")
  safe_cell "$nx" "$ny" 1
}

nearest_fruit() {
  local i hx="${body_x[0]}" hy="${body_y[0]}" x y dist best_dist=-1 best_x='' best_y=''
  for ((i=0; i<fruit_count; i++)); do
    [[ -n "${fruit_x[$i]+x}" ]] || continue
    x="${fruit_x[$i]}"
    y="${fruit_y[$i]}"
    dist=$(( (hx > x ? hx - x : x - hx) + (hy > y ? hy - y : y - hy) ))
    if (( best_dist < 0 || dist < best_dist )); then
      best_dist="$dist"
      best_x="$x"
      best_y="$y"
    fi
  done
  [[ -n "$best_x" ]] || return 1
  printf '%s %s\n' "$best_x" "$best_y"
}

try_direction_list() {
  local d seen=''
  for d in "$@"; do
    [[ -n "$d" ]] || continue
    [[ " $seen " == *" $d "* ]] && continue
    seen+=" $d"
    if direction_safe "$d"; then
      printf '%s\n' "$d"
      return 0
    fi
  done
  return 1
}

choose_safe_direction() {
  local hx="${body_x[0]}" hy="${body_y[0]}" fx fy first='' second='' left right d
  if read -r fx fy < <(nearest_fruit); then
    if (( fx < hx )); then first='LEFT'; elif (( fx > hx )); then first='RIGHT'; fi
    if (( fy < hy )); then second='UP'; elif (( fy > hy )); then second='DOWN'; fi
    if try_direction_list "$first" "$second"; then
      return 0
    fi
    if try_direction_list "$second" "$first"; then
      return 0
    fi
  fi

  left="$(left_of "$dir")"
  right="$(right_of "$dir")"
  if try_direction_list "$dir" "$left" "$right"; then
    return 0
  fi

  for d in UP RIGHT DOWN LEFT; do
    if direction_safe "$d"; then
      printf '%s\n' "$d"
      return 0
    fi
  done
  return 1
}

choose_dumb_direction() {
  local left right d
  left="$(left_of "$dir")"
  right="$(right_of "$dir")"
  if try_direction_list "$dir" "$left" "$right"; then
    return 0
  fi
  for d in UP RIGHT DOWN LEFT; do
    if direction_safe "$d"; then
      printf '%s\n' "$d"
      return 0
    fi
  done
  return 1
}

build_smart_path() {
  local start_x="${body_x[0]}" start_y="${body_y[0]}"
  local -a qx qy revx revy
  local -A seen parent
  local head=0 tail=0 steps=0 x y nx ny key nkey found='' d prev cx cy px py i

  bfs_path_x=()
  bfs_path_y=()
  qx[$tail]=$start_x; qy[$tail]=$start_y; tail=$((tail + 1))
  seen["$start_x,$start_y"]=1

  while (( head < tail && steps < MAX_AI_STEPS )); do
    x="${qx[$head]}"
    y="${qy[$head]}"
    head=$((head + 1))
    steps=$((steps + 1))
    key="$x,$y"

    if [[ -n "${fruit_hit[$key]+x}" && "$key" != "$start_x,$start_y" ]]; then
      found="$key"
      break
    fi

    for d in UP DOWN LEFT RIGHT; do
      read -r nx ny < <(next_coord "$d" "$x" "$y")
      nkey="$nx,$ny"
      [[ -n "${seen[$nkey]+x}" ]] && continue
      safe_cell "$nx" "$ny" 1 || continue
      seen["$nkey"]=1
      parent["$nkey"]="$key"
      qx[$tail]=$nx
      qy[$tail]=$ny
      tail=$((tail + 1))
    done
  done

  [[ -n "$found" ]] || return 1

  cx="${found%,*}"
  cy="${found#*,}"
  while [[ "$cx,$cy" != "$start_x,$start_y" ]]; do
    revx+=("$cx")
    revy+=("$cy")
    prev="${parent[$cx,$cy]}"
    px="${prev%,*}"
    py="${prev#*,}"
    cx="$px"
    cy="$py"
  done

  for ((i=${#revx[@]}-1; i>=0; i--)); do
    bfs_path_x+=("${revx[$i]}")
    bfs_path_y+=("${revy[$i]}")
  done
  (( ${#bfs_path_x[@]} > 0 ))
}

rebuild_auto_path() {
  path_x=()
  path_y=()
  path_index=0

  if (( W * H > MAX_AI_CELLS )); then
    path_dirty=0
    return 1
  fi

  if build_smart_path; then
    path_x=("${bfs_path_x[@]}")
    path_y=("${bfs_path_y[@]}")
    path_dirty=0
    return 0
  fi

  path_dirty=0
  return 1
}

follow_cached_path() {
  local nx ny d
  (( path_index < ${#path_x[@]} )) || return 1
  nx="${path_x[$path_index]}"
  ny="${path_y[$path_index]}"
  safe_cell "$nx" "$ny" 1 || return 1
  d="$(direction_to "${body_x[0]}" "${body_y[0]}" "$nx" "$ny")"
  opposite_dir "$dir" "$d" && return 1
  dir="$d"
  path_index=$((path_index + 1))
  move_to "$nx" "$ny"
  return 0
}

auto_step() {
  local d nx ny
  tick=$((tick + 1))

  if [[ "$AI_MODE" == "smart" ]]; then
    if follow_cached_path; then
      return
    fi

    if (( path_index < ${#path_x[@]} )); then
      path_dirty=1
    fi
    path_x=()
    path_y=()
    path_index=0
    if (( path_dirty == 1 || tick % PATH_REFRESH == 0 )); then
      rebuild_auto_path >/dev/null 2>&1 || true
      if follow_cached_path; then
        return
      fi
    fi
  fi

  if [[ "$AI_MODE" == "dumb" ]]; then
    d="$(choose_dumb_direction)" || d=''
  else
    d="$(choose_safe_direction)" || d=''
  fi

  if [[ -n "$d" ]]; then
    dir="$d"
    read -r nx ny < <(next_coord "$dir" "${body_x[0]}" "${body_y[0]}")
    move_to "$nx" "$ny"
  else
    restart_keep_score
  fi
}

manual_step() {
  local nx ny
  read -r nx ny < <(next_coord "$dir" "${body_x[0]}" "${body_y[0]}")
  move_to "$nx" "$ny"
}

handle_key() {
  local key="$1"

  case "$key" in
    $'\e[A'|w|W) set_direction 'UP' ;;
    $'\e[B'|s|S) set_direction 'DOWN' ;;
    $'\e[D'|a|A) set_direction 'LEFT' ;;
    $'\e[C'|d|D) set_direction 'RIGHT' ;;
    ' '|t|T)
      if [[ "$mode" == 'auto' ]]; then
        enter_manual
      else
        enter_auto
      fi
      ;;
    r|R)
      restart_keep_score
      ;;
    q|Q)
      exit 0
      ;;
  esac
}

read_key() {
  local first rest
  first=''
  rest=''

  if ! IFS= read -rsn1 -t "$DELAY" first; then
    return 1
  fi

  if [[ "$first" == $'\e' ]]; then
    IFS= read -rsn2 -t 0.001 rest || true
    printf '%s' "$first$rest"
  else
    printf '%s' "$first"
  fi
}

draw_line() {
  printf '\033[K%s\n' "$1"
}

draw() {
  local x y key cell now host load mode_text border line high_text idx type sym fruits_text

  now="$(date '+%Y-%m-%d %H:%M:%S')"
  host="$(hostname 2>/dev/null || echo unknown)"
  load="$(cut -d' ' -f1-3 /proc/loadavg 2>/dev/null || echo '-')"
  high_text="best:$high_score"
  (( SCORE_ENABLED == 0 )) && high_text='best:off'
  [[ "$mode" == 'auto' ]] && mode_text='AUTO' || mode_text='PLAY'
  fruits_text="$(active_fruit_count)"

  tput cup 0 0 2>/dev/null || printf '\033[H'
  draw_line " $(colorize "$COLOR_ACCENT" 'SSS Snake')  mode:$mode_text  host:$host  load:$load  time:$now"
  draw_line " total:$score_total  manual:$score_manual  away ate:$score_auto_away  restarts:$restarts  $high_text  fruits:$fruits_text"
  draw_line " controls: arrows/WASD play | T/Space auto/manual | R restart | Q quit"

  border="$TL"
  for ((x=0; x<W; x++)); do border+="$HH"; done
  border+="$TR"
  draw_line "$(colorize "$COLOR_BORDER" "$border")"

  for ((y=0; y<H; y++)); do
    line="$(colorize "$COLOR_BORDER" "$VV")"
    for ((x=0; x<W; x++)); do
      key="$x,$y"

      if (( x == body_x[0] && y == body_y[0] )); then
        cell="$(colorize "$COLOR_HEAD" "$HEAD")"
      elif [[ -n "${snake[$key]+x}" ]]; then
        cell="$(colorize "$COLOR_BODY" "$BODY")"
      elif [[ -n "${fruit_center[$key]+x}" ]]; then
        idx="${fruit_center[$key]}"
        type="${fruit_type[$idx]}"
        sym="${fruit_symbol[$type]}"
        cell="$(colorize "$COLOR_APPLE" "$sym")"
      else
        cell="$EMPTY"
      fi

      line+="$cell"
    done
    line+="$(colorize "$COLOR_BORDER" "$VV")"
    draw_line "$line"
  done

  border="$BL"
  for ((x=0; x<W; x++)); do border+="$HH"; done
  border+="$BR"
  draw_line "$(colorize "$COLOR_BORDER" "$border")"
  printf '\033[J'
}

cleanup() {
  save_high_score
  if [[ -n "$old_stty" ]]; then
    stty "$old_stty" 2>/dev/null || true
  else
    stty sane 2>/dev/null || true
  fi
  tput cnorm 2>/dev/null || true
  tput rmcup 2>/dev/null || true
  printf '\n'
}

setup_colors
load_high_score

old_stty="$(stty -g 2>/dev/null || true)"
trap cleanup EXIT
trap 'exit 130' INT
trap 'exit 143' TERM

tput smcup 2>/dev/null || true
tput civis 2>/dev/null || true
stty -echo -icanon time 0 min 0 2>/dev/null || true

reset_board
clear

while true; do
  draw

  key="$(read_key || true)"
  if [[ -n "$key" ]]; then
    handle_key "$key"
  else
    if [[ "$mode" == 'manual' ]]; then
      manual_idle=$((manual_idle + 1))
      if (( manual_idle >= IDLE_TICKS )); then
        enter_auto
      fi
    fi
  fi

  if [[ "$mode" == 'auto' ]]; then
    auto_step
  else
    manual_step
  fi
done
